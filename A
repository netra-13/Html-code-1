
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quiz App</title>
</head>
<body>
<div class="quiz-container">
    <h2>General Knowledge Quiz</h2>
    <form>
        <!-- Question 1 -->
        <div class="question">
            1. What is the capital of India?
            <div class="answers">
                <input type="radio" name="q1"> Mumbai<br>
                <input type="radio" name="q1"> Delhi<br>
                <input type="radio" name="q1"> Kolkata<br>
            </div>
        </div>
        <!-- Question 2 -->
        <div class="question">
            2. Which planet is known as the Red Planet?
            <div class="answers">
                <input type="radio" name="q2"> Earth<br>
                <input type="radio" name="q2"> Mars<br>
                <input type="radio" name="q2"> Venus<br>
            </div>
        </div>
        <!-- Question 3 -->
        <div class="question">
            3. Who wrote "Hamlet"?
            <div class="answers">
                <input type="radio" name="q3"> Charles Dickens<br>
                <input type="radio" name="q3"> William Shakespeare<br>
                <input type="radio" name="q3"> Tolstoy<br>
            </div>
        </div>
        <!-- Question 4 -->
        <div class="question">
            4. What is 5 + 7?
            <div class="answers">
                <input type="radio" name="q4"> 10<br>
                <input type="radio" name="q4"> 12<br>
                <input type="radio" name="q4"> 14<br>
            </div>
        </div>
        <!-- Question 5 -->
        <div class="question">
            5. Which gas do plants absorb?
            <div class="answers">
                <input type="radio" name="q5"> Oxygen<br>
                <input type="radio" name="q5"> Carbon Dioxide<br>
                <input type="radio" name="q5"> Nitrogen<br>
            </div>
        </div>
        <!-- Question 6 -->
        <div class="question">
            6. Largest ocean in the world?
            <div class="answers">
                <input type="radio" name="q6"> Atlantic<br>
                <input type="radio" name="q6"> Indian<br>
                <input type="radio" name="q6"> Pacific<br>
            </div>
        </div>
        <!-- Question 7 -->
        <div class="question">
            7. Which is the fastest animal?
            <div class="answers">
                <input type="radio" name="q7"> Cheetah<br>
                <input type="radio" name="q7"> Lion<br>
                <input type="radio" name="q7"> Tiger<br>
            </div>
        </div>
        <!-- Question 8 -->
        <div class="question">
            8. HTML stands for?
            <div class="answers">
                <input type="radio" name="q8"> Hyper Text Markup Language<br>
                <input type="radio" name="q8"> High Text Machine Language<br>
                <input type="radio" name="q8"> Hyper Tool Multi Language<br>
            </div>
        </div>
        <!-- Question 9 -->
        <div class="question">
            9. Which country invented pizza?
            <div class="answers">
                <input type="radio" name="q9"> France<br>
                <input type="radio" name="q9"> Italy<br>
                <input type="radio" name="q9"> USA<br>
            </div>
        </div>
        <!-- Question 10 -->
        <div class="question">
            10. Which is the largest mammal?
            <div class="answers">
                <input type="radio" name="q10"> Elephant<br>
                <input type="radio" name="q10"> Blue Whale<br>
                <input type="radio" name="q10"> Giraffe<br>
            </div>
        </div>
        <!-- Toggle Answer Key -->
        <input type="checkbox" id="show-answers" class="toggle">
        <label for="show-answers" class="btn">Show Answers</label>
        <div class="answers-key">
            <strong>Answer Key:</strong><br>
            1. Delhi<br>
            2. Mars<br>
            3. William Shakespeare<br>
            4. 12<br>
            5. Carbon Dioxide<br>
            6. Pacific<br>
            7. Cheetah<br>
            8. Hyper Text Markup Language<br>
            9. Italy<br>
            10. Blue Whale
        </div>
    </form>
</div>
</body>
</html>
